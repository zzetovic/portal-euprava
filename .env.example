# PostgreSQL
POSTGRES_PASSWORD=portal_dev

# JWT
JWT_SECRET=dev-jwt-secret-minimum-32-characters-long-change-in-prod

# SMTP (MailHog defaults for dev)
SMTP_HOST=localhost
SMTP_PORT=1025

# Storage paths (inside container)
STORAGE_ATTACHMENT_BASE_PATH=/var/portal/attachments
STORAGE_ARCHIVE_INTAKE_PATH=/var/portal/archive-staging

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# SQL Server (SEUP) — not used until section 21 TODOs are resolved
# SEUP_CONNECTION_STRING=Server=...;Database=...;User Id=...;Password=...;TrustServerCertificate=True
