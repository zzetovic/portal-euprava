@* Email template: Draft expiring soon *@
@{
    var referenceNumber = Model.ReferenceNumber;
    var expiresAt = Model.ExpiresAt;
}
<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="utf-8" />
    <style>
        body { font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; }
        .header { background: #d97706; color: white; padding: 20px; text-align: center; }
        .content { padding: 20px; }
        .reference { font-size: 18px; font-weight: bold; color: #d97706; }
        .warning { padding: 12px; background: #fffbeb; border-left: 4px solid #d97706; margin: 16px 0; }
        .footer { padding: 20px; color: #666; font-size: 12px; border-top: 1px solid #eee; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Nacrt zahtjeva uskoro istječe</h1>
    </div>
    <div class="content">
        <p>Poštovani,</p>
        <p>Vaš nacrt zahtjeva <span class="reference">@referenceNumber</span> istječe uskoro.</p>
        <div class="warning">
            <strong>Datum isteka:</strong> @expiresAt
        </div>
        <p>Dovršite i podnesite zahtjev prije navedenog datuma, inače će nacrt biti automatski obrisan.</p>
    </div>
    <div class="footer">
        <p>Ova poruka je automatski generirana. Molimo ne odgovarajte na nju.</p>
    </div>
</body>
</html>
